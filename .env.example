# ════════════════════════════════════════════════════════════════════
# LOCAL CLI MODE  →  copy this block to .env.local, fill the two keys
# ════════════════════════════════════════════════════════════════════
# ANTHROPIC_API_KEY=sk-ant-...        ← required
# TAVILY_API_KEY=tvly-...             ← required for live literature search
# (All other keys below are only needed for the full web platform)

# ─── Application ───────────────────────────────────────────────────
APP_NAME="SCI Research Platform"
ENVIRONMENT=production
DEBUG=false
SECRET_KEY=<generate-with: openssl rand -hex 32>
ALLOWED_ORIGINS=["https://yourdomain.com"]

# ─── Database ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=<strong-password>
DATABASE_URL=postgresql://sci_user:<password>@postgres:5432/sci_research

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_PASSWORD=<strong-password>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/1
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/2

# ─── AI / Claude ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_WRITING_MODEL=claude-opus-4-7
CLAUDE_FAST_MODEL=claude-sonnet-4-6
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=sci-research-platform

# ─── Vector DB ─────────────────────────────────────────────────────
QDRANT_API_KEY=<strong-key>

# ─── Object Storage ────────────────────────────────────────────────
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=<strong-password>
S3_ENDPOINT_URL=http://minio:9000

# ─── Authentication (Clerk) ────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# ─── External APIs ─────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
SEMANTIC_SCHOLAR_API_KEY=<optional>
SCITE_API_KEY=<optional>

# ─── Monitoring ────────────────────────────────────────────────────
GRAFANA_PASSWORD=<strong-password>
FLOWER_USER=admin
FLOWER_PASSWORD=<strong-password>

# ─── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://yourdomain.com
NEXT_PUBLIC_API_WS_URL=wss://yourdomain.com

# ─── Pipeline Settings ─────────────────────────────────────────────
EDITOR_MIN_SCORE=9.0
MAX_PIPELINE_ITERATIONS=10
MAX_PLAGIARISM_PERCENT=15.0
MAX_AI_DETECTION_PERCENT=5.0
