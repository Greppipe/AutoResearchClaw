# ─── Minimum keys for  python run.py  (localhost CLI) ──────────────
# Copy this file to .env.local and fill in your real keys.
# Never commit .env.local — it is in .gitignore.

ANTHROPIC_API_KEY=sk-ant-api03-...
TAVILY_API_KEY=tvly-...

# Optional: enable LangSmith tracing for debugging
# LANGSMITH_API_KEY=ls__...
# LANGSMITH_PROJECT=sci-research-local
